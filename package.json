{
  "name": "gate-keeper",
  "version": "1.0.0",
  "description": "Code quality analysis MCP server for AI-assisted development",
  "main": "dist/daemon.js",
  "scripts": {
    "build": "tsc && echo 'Build complete'",
    "build:dashboard": "cd dashboard && npm install && npm run build",
    "build:all": "npm run build && npm run build:dashboard",
    "daemon": "node dist/daemon.js",
    "dev": "npx tsx src/daemon.ts",
    "mcp": "node dist/mcp/server.js",
    "mcp:dev": "npx tsx src/mcp/server.ts",
    "setup": "bash scripts/setup.sh"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "express": "^4.18.2",
    "open": "^9.1.0",
    "typescript": "^5.3.3",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.0"
  }
}
{
  "name": "gate-keeper",
  "version": "1.0.0",
  "description": "Code quality analysis MCP server for AI-assisted development",
  "main": "dist/daemon.js",
  "scripts": {
    "build": "tsc && echo 'Build complete'",
    "build:dashboard": "cd dashboard && npm install && npm run build",
    "build:all": "npm run build && npm run build:dashboard",
    "build:csharp": "dotnet build CSharpAnalyzer -c Release",
    "daemon": "node dist/daemon.js",
    "dev": "npx tsx src/daemon.ts",
    "mcp": "node dist/mcp/server.js",
    "mcp:dev": "npx tsx src/mcp/server.ts",
    "setup": "bash scripts/setup.sh",
    "setup:portable": "npm run build:all && npx tsx src/cli/setup.ts --all",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "express": "^4.18.2",
    "open": "^9.1.0",
    "typescript": "^5.3.3",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.5",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0"
  }
}
